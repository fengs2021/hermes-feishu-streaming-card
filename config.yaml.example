# Hermes Feishu Streaming Card sidecar-only configuration
# Copy to a local path and fill credentials from your environment or secret store.

server:
  host: 127.0.0.1
  port: 8765

feishu:
  # Prefer FEISHU_APP_ID and FEISHU_APP_SECRET in real deployments.
  app_id: ""
  app_secret: ""
  base_url: https://open.feishu.cn/open-apis
  timeout_seconds: 30

card:
  # Header title shown on Feishu cards.
  title: Hermes Agent
  # Flush partial streaming text after this many milliseconds.
  max_wait_ms: 800
  # Flush partial streaming text after this many buffered characters.
  max_chars: 240
  # Footer fields and order. Supported values:
  # duration, model, input_tokens, output_tokens, context
  footer_fields:
    - duration
    - model
    - input_tokens
    - output_tokens
    - context

# Optional V3.2 multi-bot config. Existing single-bot users can leave this empty
# and rely on the top-level `feishu.app_id` / `feishu.app_secret` as the default bot.
#
# Multi-bot pattern:
# - Define each bot under `bots.items` with its own Feishu app credentials
# - Map group/private chat IDs to bot IDs under `bindings.chats`
# - Unbound sessions use `bindings.fallback_bot` (default: "default")
#
# Note: V3.2 does NOT filter group triggers. Hermes Gateway still decides
# whether to respond to a message based on its own rules (mention, private,
# reply, etc.). The sidecar only ensures the card is sent via the correct bot.
bots:
  default: default
  items:
    # Example: a dedicated bot for the sales group
    sales:
      name: Sales Group Bot
      app_id: cli_sales_xxxxx
      app_secret: ""
    # Example: a support bot for customer service
    support:
      name: Support Bot
      app_id: cli_support_yyyyy
      app_secret: ""

bindings:
  fallback_bot: default
  chats:
    # Map Feishu chat_id to bot_id defined above
    oc_xxxxxxxxxxxx: sales
    oc_yyyyyyyyyyyy: support
  # Reserved for a future release. V3.2 does not filter group triggers.
  group_rules:
    enabled: false
