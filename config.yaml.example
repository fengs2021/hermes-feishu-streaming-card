# Hermes Feishu Streaming Card sidecar-only configuration
# Copy to a local path and fill credentials from your environment or secret store.

server:
  host: 127.0.0.1
  port: 8765

feishu:
  # Prefer FEISHU_APP_ID and FEISHU_APP_SECRET in real deployments.
  app_id: ""
  app_secret: ""
  base_url: https://open.feishu.cn/open-apis
  timeout_seconds: 30

card:
  # Header title shown on Feishu cards.
  title: Hermes Agent
  # Flush partial streaming text after this many milliseconds.
  max_wait_ms: 800
  # Flush partial streaming text after this many buffered characters.
  max_chars: 240
  # Footer fields and order. Supported values:
  # duration, model, input_tokens, output_tokens, context
  footer_fields:
    - duration
    - model
    - input_tokens
    - output_tokens
    - context
